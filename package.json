{
    "name": "quanticatech",
    "version": "1.0.3",
    "main": "index.js",
    "scripts": {
        "watch:sass": "sass --watch sass/style.scss:css/style.css",
        "start": "sass --watch sass/style.scss:css/style.css --source-map",
        "compile:sass": "sass sass/style.scss css/style.comp.css",
        "prefix:css": "postcss --use autoprefixer -b 'last 10 versions' css/style.comp.css -o css/style.prefix.css",
        "compress:css": "sass css/style.prefix.css css/style.css --style compressed",
        "build:css": "npm-run-all compile:sass prefix:css compress:css",
        "build": "npm run build:css",
        "serve": "live-server --ignore=node_modules",
        "dev": "npm-run-all --parallel start serve"
    },
    "repository": {
        "type": "git",
        "url": ""
    },
    "keywords": [
        "scss",
        "starter-pack",
        "Quantica-scss"
    ],
    "author": "Hemant Bhosale",
    "license": "ISC",
    "bugs": {
        "url": ""
    },
    "homepage": "",
    "devDependencies": {
        "autoprefixer": "^10.3.6",
        "concat": "^1.0.3",
        "live-server": "^1.2.2",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.3.8",
        "postcss-cli": "^9.0.1",
        "sass": "^1.101.0"
    },
    "description": "",
    "publishConfig": {
        "registry": "https://npm.pkg.github.com/"
    }
}
